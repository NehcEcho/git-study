# ============================================
# 通用 .gitignore 模板
# 根据你的项目类型选择使用
# ============================================

# ========== 操作系统文件 ==========
.DS_Store
Thumbs.db
*.stackdump
Desktop.ini

# ========== 编辑器/IDE ==========
.vscode/
.idea/
*.sublime-*
*.swp
*.swo
*~
.project
.classpath
.settings/

# ========== 依赖目录 ==========
node_modules/
vendor/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# ========== 编译输出 ==========
dist/
build/
out/
target/
*.exe
*.dll
*.so
*.dylib
*.class

# ========== 日志文件 ==========
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========== 测试覆盖报告 ==========
coverage/
.nyc_output/
htmlcov/
.tox/
.hypothesis/
.pytest_cache/

# ========== 环境变量（重要！）==========
.env
.env.*
!.env.example
!.env.template

# ========== 临时文件 ==========
tmp/
temp/
*.tmp
*.cache
*.pid
*.seed
*.pid.lock

# ========== 包管理器锁文件（可选）==========
# 团队开发时建议保留，个人开发可忽略
# package-lock.json
# yarn.lock
# Pipfile.lock

# ========== 其他 ==========
*.local
*.bak
*.orig
